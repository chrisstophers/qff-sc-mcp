{
  "name": "qff-sc-mcp",
  "version": "0.1.0",
  "description": "Qantas Frequent Flyer Status Credit calculator MCP server for oneworld alliance flights",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "qff-sc-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:api": "tsc --noEmit -p api/tsconfig.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:api",
    "scrape": "tsx tests/qa/scraper.ts",
    "scrape:dry": "tsx tests/qa/scraper.ts --dry-run"
  },
  "keywords": [
    "qantas",
    "frequent-flyer",
    "status-credits",
    "mcp",
    "oneworld"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  }
}
